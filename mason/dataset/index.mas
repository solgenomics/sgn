
<%args>
$dataset_id
$dataset_name => ''
$dataset_description => ''
$dataset_contents => ''
$dataset_owner => 0
$dataset_is_public => 0
</%args>

<%perl>
    my $is_dataset_owner = 0;
    if ( $c->user() ) {
        $is_dataset_owner = $c->user->get_object->get_sp_person_id eq $dataset_owner;
    }

    (my $dataset_description_string = $dataset_description) =~ s|\n|<br />|g;
    my $wizard_link = '<a href=\'/breeders/search?dataset_id=' . $dataset_id . '\'>' . $dataset_name . '</a>';
</%perl>

<& /page/page_title.mas, title => "Dataset $dataset_name" &>
<& /util/import_javascript.mas, entries => [qw|dataset_scatterplot dataset|], classes => [ qw|jqueryui.js jquery.js dataset jstree.dist.jstree thickbox CXGN.Page.FormattingHelpers jquery.dataTables| ] &>

<div class="panel panel-default">
    <div class="panel-body" style="padding: 0">
        <table id="dataset-table" class="table table-hover" style="padding: 15px">
                <tr>
                    <td>Name</td>
                    <td><% $dataset_name %></td>
                </tr>


                <tr>
                    <td>Description</td>
                    <td>
                        <div id="dataset-description-update" style="display: none">
                            <textarea type="text" id="description" class="form-control" rows=5><% $dataset_description %></textarea>
                            <button class="btn btn-sm btn-primary" onclick="datasetUpdate(<% $dataset_id %>)">Update</button>
                        </div>
                        <div id="dataset-description-display">
                            <p id="dataset-description-update-content"><% $dataset_description_string %></p>
% if ( $is_dataset_owner ) {
                                <button class="btn btn-sm btn-primary" onclick="datasetEdit()">Edit</button>
% }
                        </div>
                    </td>
                </tr>

                <tr>
                    <td>Contents</td>
                    <td><% $dataset_contents %></td>
                </tr>

% if ( $is_dataset_owner ) {
                    <tr>
                        <td>Edit</td>
                        <td>
% if ( $dataset_is_public ) {
                            <button style="margin-left:4px;" class="btn btn-sm btn-primary" onclick="datasetPrivate(<% $dataset_id %>)">Make Private</button>
% } else {
                            <button style="margin-left:4px;" class="btn btn-sm btn-primary" onclick="datasetPublic(<% $dataset_id %>)">Make Public</button>
% }
                            <button style="margin-left:4px;" class="btn btn-sm btn-danger" onclick="datasetDelete(<% $dataset_id %>)">Delete</button>
                        </td>
                    </tr>
% }

                <tr>
                    <td>Select Dataset in Wizard</td>
                    <td><% $wizard_link %></td>
                </tr>

                <tr>
                    <td>Analyses using this dataset</td>
                    <td id="dataset_analysis_usage"></td>
                </tr>
        </table>
    </div>
</div>

<& /page/detail_page_2_col_section.mas, info_section_title => "<h4 style='display:inline'>Outlier Detection</h4>", info_section_subtitle => '', icon_class => "glyphicon glyphicon-signal", info_section_id => "dataset_outlier_detection", dataset_id => $dataset_id, dataset_name => $dataset_name &>

<& /page/detail_page_2_col_section.mas, info_section_title => "<h4 style='display:inline'>Analysis Tools</h4>", info_section_subtitle => '', icon_class => "glyphicon glyphicon-wrench", info_section_id => "dataset_analysis_tools", dataset_id => $dataset_id, dataset_name => $dataset_name &>

<& /page/detail_page_2_col_section.mas, info_section_title => "<h4 style='display:inline'>Tool Compatibility</h4>", info_section_subtitle => '', icon_class => "glyphicon glyphicon-check", info_section_id => "dataset_tool_compatibility", dataset_id => $dataset_id, dataset_name => $dataset_name &>

<& /page/detail_page_2_col_section.mas, info_section_title => "<h4 style='display:inline'>Publish Dataset</h4>", info_section_subtitle => '', icon_class => "glyphicon glyphicon-export", info_section_id => "dataset_publish", dataset_id => $dataset_id, dataset_name => $dataset_name, is_dataset_owner => $is_dataset_owner &>


<script>

jQuery(document).ready(function() {
    jQuery.ajax({
        type: 'GET',
        url: '/ajax/dataset/get_child_analyses/<% $dataset_id %>',
        success: function(response) {
            if (response.error){
                alert(response.error);
            } else {
                jQuery('#dataset_analysis_usage').html(response.analysis_html_list);
            }
        },
        error: function(response) {
            alert("Error retrieving analyses using this dataset.");
        }
    });
});

</script>


<style>
    #dataset-table > tbody:nth-child(1) > tr > td:nth-child(1) {
        font-weight: bold;
    }
</style>