<%args>
$dataset_id
$dataset_name
$is_dataset_owner => 0
$is_dataset_public => 0
</%args>

<%once>
    my $project_name = $c->get_conf('project_name');
    my $user = $c->user();
    my $user_name = $user ? $user->get_first_name() . " " . $user->get_last_name() : "";
</%once>

<div id="dataset-archive-loading" style="margin: 50px auto; text-align: center">
    <p><em>Loading...</em></p>
</div>

<div id="dataset-archive-enabled" style="display: none">
% if ( $is_dataset_public ) {
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Date Published</th>
                <th>User</th>
                <th>Files</th>
                <th>Published To</th>
                <th></th>
            </tr>
        </thead>
        <tbody id="dataset-publish-status"></tbody>
    </table>

% if ( $is_dataset_owner ) {
        <br /><br />
        <button id="dataset-generate-archive" class="btn btn-primary"><span class="glyphicon glyphicon-folder-open"></span>&nbsp;&nbsp;Generate Archive Files</button>
% }
% } else {
    <& /generic_message.mas, message=>"<p>Dataset Publishing is only enabled on public datasets.</p><p>Change the dataset visibility to Public to enable this feature.</p>" &>
% }
</div>

<div id="dataset-archive-disabled" style="display: none">
    <& /generic_message.mas, message=>"<p>Dataset Publishing has not been enabled on this database.</p><p>Contact an administrator to have this feature enabled.</p>" &>
</div>

<br /><br />

<&| /page/info_section.mas, id=> "publish_dataset_info", title => "Information about Publishing Datasets", collapsible=>1, collapsed=>1, hide_if_empty=>1 &>
    <p>Dataset publishing allows the owner of a dataset to take a snapshot of the data contained within the dataset and publish it to an external service (such as FigShare), where it can be made publicly available and have a DOI assigned to it.</p>
    <p>The steps to publish a dataset are:</p>
    <ol>
        <li>Make the dataset public</li>
        <li>Generate the archived files - this creates a static snapshot of the data within the dataset at the time when the files are generated</li>
        <li>Publish the files to an external service - this will upload the archived files to a new or existing dataset on the external service</li>
    </ol>
</&>


<div class="modal fade" id="dataset-archive-generate-dialog" name="dataset-archive-generate-dialog" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
          <h4 class="modal-title">Generating Archive Files</h4>
      </div>
      <div class="modal-body">
        <div class="container-fluid" id="dataset-archive-generate-dialog-content">
        </div>
      </div>
      <div class="modal-footer">
        <button id="dataset-archive-generate-dialog-close" type="button" class="btn btn-default" data-dismiss="modal">Close</button>
    </div>
    </div>
  </div>
</div>

<div class="modal modal-md fade" id="dataset-archive-publish-dialog" name="dataset-archive-publish-dialog" tabindex="-1" role="dialog" aria-labelledby="datasetArchivePublishDialog" data-backdrop="static" data-keyboard="false">
  <div class="modal-dialog modal-xl" role="document">
    <div class="modal-content ui-front">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" id="datasetArchivePublishDialog">Publish Dataset</h4>
      </div>
      <div class="modal-body">
        <div class="container-fluid">
            <ol id="dataset-archive-publish-instructions">
                <li>
                    <p>Select the external service to publish this dataset to:</p>
                    <select id="dataset-archive-publish-services" class="form-control"></select>
                </li>
                <li class="dataset-archive-publish-connect">
                    <p>Make sure you have an account and are logged in to <span class="dataset-archive-publish-service-name"></span></p>
                    <a id="dataset-archive-publish-account" class="btn btn-info btn-sm" href="#" target="_blank">
                        <span class="glyphicon glyphicon-user"></span>&nbsp;&nbsp;View your <span class="dataset-archive-publish-service-name"></span> account
                    </a>
                <li class="dataset-archive-publish-connect">
                    <p>Grant <% $project_name %> access to your <span class="dataset-archive-publish-service-name"></span> account</p>
                    <button id="dataset-archive-publish-connect" class="btn btn-primary btn-sm">
                        <span class="glyphicon glyphicon-resize-small"></span>&nbsp;&nbsp;Connect Accounts
                    </button>
                </li>
                <li class="dataset-archive-publish-connected">
                    <p>You are connected to this <span class="dataset-archive-publish-service-name"></span> account:</p>
                    <p><strong>Name:</strong> <span id="dataset-archive-publish-connected-name"></span></p>
                    <p><strong>Email:</strong> <span id="dataset-archive-publish-connected-email"></span></p>
                    <button id="dataset-archive-publish-disconnect" class="btn btn-danger btn-sm">
                        <span class="glyphicon glyphicon-resize-full"></span>&nbsp;&nbsp;Disconnect Accounts
                    </button>
                </li>
                <li class="dataset-archive-publish-connected">
                    <p>Select a <span class="dataset-archive-publish-service-name"></span> dataset to associate this data with:</p>
                    <select id="dataset-archive-publish-articles" class="form-control">
                        <option value="">Create a new <span class="dataset-archive-publish-service-name"></span> dataset</option>
                    </select>
                    <hr />
                    <label>Title:</label>
                    <div class="input-group">
                        <span id="dataset-archive-publish-article-title-addon" class="input-group-addon"></span>
                        <input id="dataset-archive-publish-article-title" class="form-control dataset-archive-publish-article-details" />
                    </div>
                    <br />
                    <label>Description:</label>
                    <textarea id="dataset-archive-publish-article-description" class="form-control dataset-archive-publish-article-details"></textarea>
                    <br />
                    <label>Additional Authors (one per line):</label>
                    <textarea id="dataset-archive-publish-article-authors" class="form-control dataset-archive-publish-article-details" placeholder="You will automatically be added as an Author"></textarea>
                    <br />
                    <p><em>The dataset metadata can be updated later on <span class="dataset-archive-publish-service-name dataset-archive-publish-article-details"></span> until a DOI is generated</em></p>
                </li>
                <li class="dataset-archive-publish-connected">
                    <p>Send and attach the files to the selected <span class="dataset-archive-publish-service-name"></span> dataset.</p>
                    <button id="dataset-archive-publish-send" class="btn btn-primary btn-sm">
                        <span class="glyphicon glyphicon-export"></span>&nbsp;&nbsp;<span id="dataset-archive-publish-send-label">Send Files</span>
                    </button>
                    <br /><br />
                    <div class="progress">
                        <div id="dataset-archive-publish-send-pb" class="progress-bar progress-bar-striped" role="progressbar" style="width: 0%;">
                            <span class="sr-only">60% Complete</span>
                        </div>
                    </div>
                    <div class="progress">
                        <div id="dataset-archive-publish-send-subpb" class="progress-bar progress-bar-info" role="progressbar" style="width: 0%;">
                            <span class="sr-only">60% Complete</span>
                        </div>
                    </div>
                    <div style="display: flex; justify-content: space-between; gap: 15px">
                        <p id="dataset-archive-publish-send-status"></p>
                        <p id="dataset-archive-publish-send-substatus" style="font-size: 95%; font-style: italic"></p>
                    </div>
                </li>
            </ol>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
var ISSUES = {};             // Status information about individual published issues of the dataset
var SELECTED_ISSUE;          // The currently selected published issue
var SERVICES = {};           // Information about available external services
var SELECTED_SERVICE = {};   // The currently selected external service
var SELECTED_ACCOUNT = {};   // Information on the currently selected account

jQuery(document).ready(() => {
    updateIssues();
    updateServices();

    jQuery("#dataset-generate-archive").click(initArchive)
    jQuery("#dataset-archive-publish-services").on("change", onServiceChanged);
    jQuery("#dataset-archive-publish-connect").click(connectService);
    jQuery("#dataset-archive-publish-disconnect").click(disconnectService);
    jQuery("#dataset-archive-publish-send").click(sendArchive);
    jQuery("#dataset-archive-publish-articles").on("change", onArticleChanged);
});


/**
 * Get the available external services from the server config
 * - Call displayServices() on success
 */
function updateServices() {
    jQuery.ajax({
        url: '/ajax/dataset/publish/services',
        success: (resp) => {
            if ( resp?.error ) {
                alert(resp.error);
            }
            else {
                displayServices(resp)
            }
        },
        error: () => {
            alert("Could not get external services");
        }
    });
}

/**
 * Display the external services as options in the select menu
 */
function displayServices(services = {}) {
    SERVICES = services;

    if ( Object.keys(SERVICES).length > 0 ) {
        jQuery("#dataset-archive-loading").hide();
        jQuery("#dataset-archive-disabled").hide();
        jQuery("#dataset-archive-enabled").show();
    }
    else {
        jQuery("#dataset-archive-loading").hide();
        jQuery("#dataset-archive-enabled").hide();
        jQuery("#dataset-archive-disabled").show();
    }

    var html = "";
    Object.keys(SERVICES).sort().forEach((key) => {
        html += `<option value='${key}'>${SERVICES[key].display_name} [${SERVICES[key].web_url}]</option>`;
    });
    jQuery("#dataset-archive-publish-services").html(html);
    onServiceChanged();
}

/**
 * Handle a service change
 * - display selected service name throughout the dialog
 * - update the link for the user to check their account
 * - call updateConnection() to check for already-provided user account on the service
 */
function onServiceChanged() {
    SELECTED_SERVICE = SERVICES[jQuery("#dataset-archive-publish-services").val()];

    if ( SELECTED_SERVICE ) {
        jQuery(".dataset-archive-publish-service-name").html(SELECTED_SERVICE.display_name);
        jQuery("#dataset-archive-publish-account").attr('href', `${SELECTED_SERVICE.web_url}${SELECTED_SERVICE.user_path}`);
    }
    updateConnection();
}

/**
 * Check the User Prefs on the server to see if the user has an account with the selected service
 * - Call displayConnection()
 */
function updateConnection() {
    if ( SELECTED_SERVICE && SELECTED_SERVICE.key ) {
        jQuery.ajax({
            url: `/ajax/dataset/publish/connection/${SELECTED_SERVICE.key}`,
            success: (resp) => {
                if ( resp?.error ) {
                    alert("Could not update connection info [" + resp.error + "]");
                    displayConnection();
                }
                else {
                    displayConnection(resp);
                }
            },
            error: () => {
                alert("Could not update connection info");
                displayConnection();
            }
        });
    }
    else {
        displayConnection();
    }
}

/**
 * Display the user's stored account with the selected service
 * - check if provided token is still valid
 * - toggle connection / connect steps depending on account status and selected service
 */
function displayConnection(account = {}) {
    SELECTED_ACCOUNT = account;

    // A service and account have been selected
    if ( !!SELECTED_SERVICE && SELECTED_ACCOUNT.hasOwnProperty('token') && SELECTED_ACCOUNT.hasOwnProperty('profile') ) {
        const now = new Date().getTime();
        if ( SELECTED_ACCOUNT.token.expiration > now ) {
            jQuery(".dataset-archive-publish-connected").show();
            jQuery(".dataset-archive-publish-connect").hide();
            jQuery("#dataset-archive-publish-connected-name").html(SELECTED_ACCOUNT.profile.first_name + ' ' + SELECTED_ACCOUNT.profile.last_name);
            jQuery("#dataset-archive-publish-connected-email").html(SELECTED_ACCOUNT.profile.email);
            jQuery("#dataset-archive-publish-send").attr("disabled", false);
            updateArticles();
            return;
        }
    }

    // Only a service has been selected
    else if ( !!SELECTED_SERVICE ) {
        jQuery(".dataset-archive-publish-connected").hide();
        jQuery(".dataset-archive-publish-connect").show();
        jQuery("#dataset-archive-publish-send").attr("disabled", true);
    }

    // Service not selected
    else {
        jQuery(".dataset-archive-publish-connected").hide();
        jQuery(".dataset-archive-publish-connect").hide();
        jQuery("#dataset-archive-publish-send").attr("disabled", true);
    }
}

/**
 * Start the OAuth flow to allow the user to connect their account on the selected service
 * - launches a pop-up window to grant access to the user's account
 * - the pop-up will store the user's info in the User Prefs on the server
 * - once the pop-up is closed, call updateConnection() to reflect changes
 */
function connectService() {
    if ( SELECTED_SERVICE ) {
        jQuery("#dataset-archive-publish-connect").attr("disabled", true);
        window.authorize_data = { service: SELECTED_SERVICE };
        const popup = window.open(`/dataset/publish/authorize/${SELECTED_SERVICE.key}`, '_authorize', 
            `toolbar=no,
            location=no,
            status=no,
            menubar=no,
            scrollbars=yes,
            resizable=yes,
            width=700, 
            height=700`
        );

        if ( !popup ) {
            jQuery("#dataset-archive-publish-connect").attr("disabled", false);
            alert("You must allow popup windows in your browser to continue");
        }

        const interval = setInterval(() => {
            if (popup.closed) {
                clearInterval(interval);
                jQuery("#dataset-archive-publish-connect").attr("disabled", false);
                window.authorize_data = {};
                updateConnection();
            }
        }, 500);
    }
}

/**
 * Remove the selected account from the User Prefs
 * - call updateConnection() to reflect the changes
 */
function disconnectService() {
    SELECTED_ACCOUNT = {};
    jQuery.ajax({
        url: `/ajax/dataset/publish/connection/remove/${SELECTED_SERVICE.key}`,
        method: 'DELETE',
        success: () => {
            updateConnection();
        }
    });
}

/**
 * Get a list of the user's account articles
 * - Call displayArticles() with the results
 */
function updateArticles() {
    jQuery.ajax({
        url: `/ajax/dataset/publish/articles/${SELECTED_SERVICE.key}`,
        success: (resp) => {
            if ( resp?.error ) {
                alert(resp.error)
            }
            else {
                displayArticles(resp?.articles);
            }
        },
        error: () => {
            alert("Could not get account articles");
        }
    });
}

/**
 * Display the user's account articles in the article select menu
 * @param articles = Array of article metadata
 */
function displayArticles(articles = []) {
    var html = `<option value="">Create a new ${SELECTED_SERVICE.display_name} dataset</option>`;
    articles.forEach((a) => {
        html += `<option value='${a.id}'>${a.title}</a>`;
    });
    jQuery("#dataset-archive-publish-articles").html(html);
    onArticleChanged();
}

/**
 * Handle a changed article
 * - If a specific article is selected, fetch and display its details
 * - If a new article is selected, clear the form
 */
async function onArticleChanged() {
    var selected = jQuery("#dataset-archive-publish-articles").val();
    if ( selected && selected !== '' ) {
        jQuery("#dataset-archive-publish-send").attr("disabled", true);
        jQuery(".dataset-archive-publish-article-details").attr("disabled", true);
        try {
            const details = await getArticleDetails(SELECTED_SERVICE.key, selected);
            jQuery("#dataset-archive-publish-article-title").val(details.title);
            jQuery("#dataset-archive-publish-article-title-addon").html(details.status.toUpperCase());
            jQuery("#dataset-archive-publish-article-description").val(details.description);
            jQuery("#dataset-archive-publish-article-authors").val(details.authors.map((e) => e.full_name).join('\n'));
            jQuery("#dataset-archive-publish-send-label").html("Add files to selected dataset");
            jQuery("#dataset-archive-publish-send").attr("disabled", false);
        }
        catch (err) {
            alert(err);
        }
    }
    else {
        jQuery("#dataset-archive-publish-send").attr("disabled", false);
        jQuery(".dataset-archive-publish-article-details").attr("disabled", false);
        jQuery("#dataset-archive-publish-article-title").val("");
        jQuery("#dataset-archive-publish-article-title-addon").html("NEW");
        jQuery("#dataset-archive-publish-article-description").val("");
        jQuery("#dataset-archive-publish-article-authors").val("");
        jQuery("#dataset-archive-publish-send-label").html("Create new dataset and add files");
    }
}

/**
 * Get the details of the specified article from the external service
 * @param service = key of the external service where the article is hosted
 * @param article_id = id of the specific article
 */
function getArticleDetails(service, article_id) {
    return new Promise((resolve, reject) => {
        jQuery.ajax({
            url: `/ajax/dataset/publish/articles/${service}/${article_id}`,
            success: (resp) => {
                if ( resp?.error ) {
                    reject(`Could not get article details [${resp.error}]`);
                }
                else if ( resp?.article ) {
                    resolve(resp.article);
                }
            },
            error: () => {
                reject("Could not get article details");
            }
        });
    })
}

/**
 * Get the stored published metadata for this dataset
 * - Call displayIssues() with the results
 */
function updateIssues() {
    jQuery.ajax({
        url: '/ajax/dataset/publish/issues/<% $dataset_id %>',
        success: (resp) => {
            if ( resp?.error ) {
                alert(`Could not get the dataset published issues [${resp.error}]`);
            }
            else {
                displayIssues(resp?.published);
            }
        },
        error: () => {
            alert("Could not get dataset published issues");
        }
    });
}

/**
 * Display the stored published metadata
 * @param issues = Object of issue metadata, where the key is the issue key
 */
async function displayIssues(issues = {}) {
    ISSUES = issues;
    const keys = Object.keys(ISSUES);
    const rows = [];
    if ( keys.length > 0 ) {
        for ( const k of keys ) {
            const s = ISSUES[k];
            const types = Object.keys(s.data || {});
            let overallSubmitted = false;
            let overallComplete = true;

            // Publish date
            var html = `<td>${new Date(s.ts).toLocaleString()}</td>`;

            // Publish User
            html += `<td><a href='/solpeople/personal-info.pl?sp_person_id=${s.user.id}'>${s.user.name}</a></td>`;

            // File List
            html += `<td><ul style='padding-left: 15px'>`;
            for ( const t of types ) {
                const file = s.data[t].file
                if ( file ) {
                    const url = `/ajax/dataset/publish/file/<% $dataset_id %>/${k}/${t}`;

                    // Check the status of each file, to see if it's been uploaded
                    let isSubmitted = s.data[t].submitted?.file_id;
                    let isComplete = s.data[t].complete === 1;

                    // Display the file name, link to download, and check if completely uploaded
                    html += `<li>`;
                    html += `<a href='${url}' target='_blank'>${file}</a>`;
                    if ( isSubmitted && isComplete ) html += `&nbsp;&nbsp;<span class='glyphicon glyphicon-ok text-success'></span>`;
                    html += `</li>`;

                    if ( isSubmitted ) overallSubmitted = true;
                    if ( !isComplete ) overallComplete = false;
                }
            };
            html += `</ul></td>`;

            // Display external reference, if published
            if ( s.article?.id ) {
                html += `<td><div style="display: flex; flex-direction: column; gap: 15px">`;

                // Display Public Link
                if ( s.article.is_public ) {
                    html += `<div><span class="label label-primary">Public</span>&nbsp;<a href='${s.article.url_public_html}' target='_blank'>${s.article.title}</a></div>`;
                }

                // Display Private Link, only to the dataset owner
% if ( $is_dataset_owner ) {
                    html += `<div><span class="label label-info">Preview</span>&nbsp;<a href='${s.article.url_private_html}' target='_blank'>${s.article.title}</a></div>`;
% }

                // Display DOI, if available
                if ( s.article.doi && s.article.doi !== '' ) html += `<div><a href='https://doi.org/${s.article.doi}' target='_blank'>${s.article.doi}</a></div>`;
                html += `</div></td>`;
            }
            else {
                html += `<td><em>Not published</em></td>`;
            }

            // Display actions only to owner
% if ( $is_dataset_owner ) {
            html += `<td><div style='display: flex; flex-wrap: wrap; gap: 5px;'>`
            if ( !overallSubmitted || !overallComplete ) html += `<button class='btn btn-primary btn-xs' onclick='uploadIssue(${s.key})'><span class='glyphicon glyphicon-export'></span>&nbsp;&nbsp;Upload</button>`;
            html += `<button class='btn btn-danger btn-xs' onclick='removeIssue(${s.key})'><span class='glyphicon glyphicon-trash'></span>&nbsp;&nbsp;Remove</button>`;
            html += `</div></td>`;
% } else {
            html += `<td></td>`;
% }
            rows.push(html);
        }

        jQuery("#dataset-publish-status").html(`<tr>${rows.join('</tr><tr>')}</tr>`);
    }
    else {
        const html = "<tr><td colspan=5><p style='text-align: center'><em>This dataset has not been published</em></p><br /><p>To publish this dataset, first generate a set of archived files.</p></td></tr>";
        jQuery("#dataset-publish-status").html(html);
    }
}

/**
 * Generate the archived files that are stored on breedbase
 * - Initialize a new issue for this dataset, which calculates which files need to be generated
 * - After initialization, display the generate dialog and start to generate each file
 */
function initArchive() {
    jQuery("#dataset-archive-generate-dialog-content").html("<p>Analyzing Dataset...</p>");
    jQuery("#dataset-archive-generate-dialog").modal("show");
    jQuery("#dataset-archive-generate-dialog-close").attr("disabled", true);
    jQuery.ajax({
        url: '/ajax/dataset/publish/init/<% $dataset_id %>',
        success: (resp = {}) => {
            if ( resp?.error ) {
                alert(`Could not initialize dataset archive files [${resp.error}]`);
            }
            else {
                const { key, data } = resp;
                displayArchiveFiles(key, data);
            }
        },
        error: () => {
            alert(`Could not initialize dataset archive files`);
        }
    });
}

/**
 * Display the table of archive files to generate in the modal dialog
 * @param key = the key for the specific issue being generated
 * @param data = Object of archive file info (where the key is the file type and the value is the IDs of the items in the file type)
 * - This will display the generate files modal with the table of file types
 * - This will call generateArchiveFile() in sequence for each file type
 */
async function displayArchiveFiles(key, data = {}) {
    const types = Object.keys(data);

    // Display the file type table
    let html = `<p>Files to generate:</p>`;
    html += `<table class='table table-striped'>`;
    html += `<thead><tr><th>Data Type</th><th>Item Count</th><th>Status</th></tr></thead>`;
    for (const t of types ) {
        const ids = data[t];
        if ( ids && ids.length > 0 ) {
            html += `<tr><td>${t}</td><td>${ids.length}</td><td id='dataset-archive-generate-dialog-status-${t}'><span class='glyphicon glyphicon-option-horizontal'></span>&nbsp;&nbsp;<em>Pending...</em></td></tr>`;
        }
    }
    html += `</table>`
    jQuery("#dataset-archive-generate-dialog-content").html(html);

    // Generate each file type
    for ( const t of types ) {
        try {
            const ids = data[t];
            if ( ids && ids.length > 0 ) {
                const file = await generateArchiveFile(key, t);
                if ( file && file !== '' ) {
                    jQuery(`#dataset-archive-generate-dialog-status-${t}`).html(`<strong><span class='glyphicon glyphicon-ok text-success'></span></strong>&nbsp;&nbsp;Created archived file: ${file}`);
                }
                else {
                    jQuery(`#dataset-archive-generate-dialog-status-${t}`).html(`<strong><span class='glyphicon glyphicon-exclamation-sign text-danger'></span></strong>&nbsp;&nbsp;Could not generate file`);
                }
            }
        }
        catch (err) {
            jQuery(`#dataset-archive-generate-dialog-status-${t}`).html(`<strong><span class='glyphicon glyphicon-exclamation-sign text-danger'></span></strong>&nbsp;&nbsp;${err}`);
        }
    }

    // Refresh the Issues
    jQuery("#dataset-archive-generate-dialog-close").attr("disabled", false);
    updateIssues();
}

/**
 * Generate an archived file for a specific data type
 * @param key = the issue key
 * @param type = the data type
 */
function generateArchiveFile(key, type) {
    return new Promise((resolve, reject) => {
        jQuery.ajax({
            url: '/ajax/dataset/publish/generate',
            method: 'POST',
            data: {
                dataset_id: <% $dataset_id %>,
                key,
                type
            },
            success: (resp) => {
                if ( resp?.error ) {
                    reject(`Could not generate ${type} file [${resp.error}]`);
                }
                else {
                    resolve(resp.file);
                }
            },
            error: () => {
                reject(`Could not generate ${type} file`);
            }
        });
    })
}


/**
 * Show the publish dialog for the specific issue
 */
function uploadIssue(key) {
    if ( confirm("By continuing, you acknowledge that the data is this dataset can be made publicly available") ) {
        SELECTED_ISSUE = ISSUES[key];
        jQuery("#dataset-archive-publish-dialog").modal("show");
    }
}

/**
 * Remove the issue from the dataset
 * - This removes the archived files and the metadata stored with the dataset
 * - Call updateIssues() when complete to reflect changes
 */
function removeIssue(key) {
    if (confirm("Are you sure you want to unlink this published metadata from the dataset?  This will remove the archived data on this server and the connection between the dataset and the external service.  This will NOT remove anything from the external service.") ) {
        jQuery.ajax({
            url: `/ajax/dataset/publish/issues/remove/<% $dataset_id %>/${key}`,
            success: (resp) => {
                if ( resp?.error ) {
                    alert(`Could not remove dataset published issues [${resp.error}]`);
                }
                else {
                    updateIssues();
                }
            },
            error: () => {
                alert("Could not remove dataset published issues");
            }
        });
    }
}

/**
 * Submit the archived files to a new or existing dataset on the external service
 * - This will call createArticle() to create a new article on the service, if needed
 * - Submit each of the dataset's archived files, using submitFile() to the specified article
 * - Upload each of the chunks for each file
 * - Finalize the file
 * - Update the Issues when complete to reflect the changes
 */
async function sendArchive() {
    try {
        jQuery("#dataset-archive-publish-send").attr("disabled", true);
        let article_id = jQuery("#dataset-archive-publish-articles").val();
        const types = [];
        for ( const t of Object.keys(SELECTED_ISSUE.data || {}) ) {
            if ( SELECTED_ISSUE.data[t].file ) {
                types.push(t);
            }
        }

        let total = !article_id || article_id === '' ? types.length+1 : types.length;
        let count = 0;

        // Create article first, if necessary
        if ( !article_id || article_id === '' ) {
            const title = jQuery("#dataset-archive-publish-article-title").val();
            progress({ msg: `Creating new dataset: ${title}`, count, total });
            article_id = await createArticle();
            count ++;
        }

        // Submit each of the file types
        for (const t of types) {
            let subTotal = 1;
            let subCount = 0;

            // Submit the file
            progress({ msg: `Sending data type: ${t}`, count, total });
            subProgress({ clear: true });
            const { parts = {}, file_id, upload_url } = await submitFile(article_id, t);
            subTotal = Object.keys(parts).length + 1;
            subCount++;

            // Upload each part of the file
            const partNos = Object.keys(parts);
            for ( const partNo of partNos ) {
                const part = parts[partNo];
                subProgress({ msg: `Uploading chunk: ${partNo}`, count: subCount, total: subTotal });
                await submitPart(t, upload_url, part);
                subCount++;
            };

            // Finalize the File
            subProgress({ msg: `Finalizing File`, count: subCount, total: subTotal });
            await finalizeFile(t, file_id, article_id);

            // Show success for file
            subCount++;
            count++;
            subProgress({ msg: '', count: subCount, total: subTotal });
            progress({ msg: `Uploaded file: ${t}`, count, total });
        };

        // Show completed status
        count++;
        progress({ msg: `<strong>All Files Uploaded!</strong>`, count, total });
        subProgress({ clear: true });
        jQuery("#dataset-archive-publish-send").attr("disabled", false);
        updateIssues();
    }
    catch (err) {
        jQuery("#dataset-archive-publish-send").attr("disabled", false);
        fail(err);
    }
}

/**
 * Create a new article on the exernal service
 * - This uses the user-provided title, description, and additonal authors
 * - This will resolve with the new article id, if successful
 */
function createArticle() {
    return new Promise((resolve, reject) => {
        const title = jQuery("#dataset-archive-publish-article-title").val();
        const description = jQuery("#dataset-archive-publish-article-description").val();
        const authors = jQuery("#dataset-archive-publish-article-authors").val();

        if ( !title || title === '' ) return reject('Please provide a name for the new dataset');
        if ( !description || description === '' ) return reject('Please provide a description for the new dataset');

        jQuery.ajax({
            url: `/ajax/dataset/publish/articles/new`,
            method: 'POST',
            data: {
                dataset_id: <% $dataset_id %>,
                service: SELECTED_SERVICE.key,
                title,
                description,
                authors
            },
            success: (resp) => {
                if ( resp?.error || !resp?.entity_id) {
                    reject(`Could not create new article [${resp.error}]`);
                }
                else {
                    resolve(resp.entity_id);
                }
            },
            error: () => {
                reject("Could not create new article")
            }
        });
    });
}

/**
 * Submit the specified file to the specified article
 * - This creates the file entry, but does not upload the content
 */
function submitFile(article, data_type) {
    return new Promise((resolve, reject) => {
        jQuery.ajax({
            url: `/ajax/dataset/publish/submit`,
            method: 'POST',
            data: {
                service: SELECTED_SERVICE.key,
                article_id: article,
                dataset_id: <% $dataset_id %>,
                key: SELECTED_ISSUE.key,
                type: data_type
            },
            success: (resp) => {
                if ( resp?.error ) {
                    reject(`Could not submit data type: ${data_type} [${resp.error}]`);
                }
                else {
                    resolve(resp);
                }
            },
            error: () => {
                reject(`Could not submit data_type: ${data_type}`);
            }
        });
    });
}

/**
 * Upload the specified chunk of a file to the submitted file upload URL
 */
function submitPart(data_type, upload_url, part) {
    return new Promise((resolve, reject) => {
        console.log("SUBMIT PART");
        console.log(part);

        if ( part.status === 'COMPLETE' ) {
            return resolve();
        }

        jQuery.ajax({
            url: `/ajax/dataset/publish/upload`,
            method: 'POST',
            data: {
                service: SELECTED_SERVICE.key,
                dataset_id: <% $dataset_id %>,
                key: SELECTED_ISSUE.key,
                type: data_type,
                partNo: part.partNo,
                startOffset: part.startOffset,
                endOffset: part.endOffset,
                uploadUrl: upload_url
            },
            success: (resp) => {
                if ( resp?.error ) {
                    reject(`Could not upload file: ${data_type} [${resp.error}]`);
                }
                else {
                    resolve();
                }
            },
            error: () => {
                reject(`Could not upload file: ${data_type}`);
            }
        });
    });
}

/**
 * Finalize the file upload, done after all of the parts have been uploaded
 */
function finalizeFile(data_type, file_id, article_id) {
    return new Promise((resolve, reject) => {
        jQuery.ajax({
            url: '/ajax/dataset/publish/finalize',
            method: 'POST',
            data: {
                service: SELECTED_SERVICE.key,
                dataset_id: <% $dataset_id %>,
                key: SELECTED_ISSUE.key,
                type: data_type,
                file_id: file_id,
                article_id: article_id
            },
            success: (resp) => {
                if ( resp?.error ) {
                    reject(`Could not finalize file: ${data_type} [${resp.error}]`);
                }
                else {
                    resolve();
                }
            },
            error: () => {
                reject(`Could not finalize file: ${data_type}`);
            }
        });
    });
}


/**
 * Set main progress and message
 */
function progress({ msg, count, total, clear } = {}) {
    if ( clear ) {
        jQuery("#dataset-archive-publish-send-pb").css("width", `0%`);
        jQuery("#dataset-archive-publish-send-status").html("");
        return;
    }

    const percent = (count/total)*100;

    jQuery("#dataset-archive-publish-send-pb").removeClass('progress-bar-danger');
    if ( percent >= 100 ) {
        jQuery("#dataset-archive-publish-send-pb").addClass('progress-bar-success');
        jQuery("#dataset-archive-publish-send-pb").removeClass('progress-bar-info');
        jQuery("#dataset-archive-publish-send-pb").removeClass('active');
    }
    else {
        jQuery("#dataset-archive-publish-send-pb").removeClass('progress-bar-success');
        jQuery("#dataset-archive-publish-send-pb").addClass('progress-bar-info');
        jQuery("#dataset-archive-publish-send-pb").addClass('active');
    }

    jQuery("#dataset-archive-publish-send-pb").css("width", `${percent}%`);
    jQuery("#dataset-archive-publish-send-status").html(msg);
}

/**
 * Set error message
 */
function fail(msg) {
    jQuery("#dataset-archive-publish-send-pb").removeClass('active');
    jQuery("#dataset-archive-publish-send-pb").removeClass('progress-bar-success');
    jQuery("#dataset-archive-publish-send-pb").removeClass('progress-bar-info');
    jQuery("#dataset-archive-publish-send-pb").addClass('progress-bar-danger');
    jQuery("#dataset-archive-publish-send-pb").css("width", `100%`);
    jQuery("#dataset-archive-publish-send-status").html(`<strong>(Upload Failed) ${msg}</strong>`);
}

/**
 * Set secondary progress and message
 */
function subProgress({ msg, count, total, clear } = {}) {
    if ( clear ) {
        jQuery("#dataset-archive-publish-send-subpb").css("width", `0%`);
        jQuery("#dataset-archive-publish-send-substatus").html("");
        return;
    }

    const percent = (count/total)*100;

    jQuery("#dataset-archive-publish-send-subpb").css("width", `${percent}%`);
    jQuery("#dataset-archive-publish-send-substatus").html(msg);
}
</script>


