<%args>
$sp_person_id
$locations
$geojson_locations
$breeding_programs
$timestamp
$preferred_species => ""
$editable_stock_props => {}
$editable_stock_props_definitions => {}
$facilities => ()
$management_factor_types => ()
$design_types => ()
$default_seedlot_material_type => undef
$editable_vector_props
$allowed_upload_types => undef
</%args>

<%perl>
    my $user_role = '';
    if ($c->user) {
        $user_role = $c->user->get_object()->get_user_type();
    }
</%perl>

<& /util/import_javascript.mas, entries => ["job", "upload_factory"], classes => [ 'bootstrap_min.js', 'jquery.iframe-post-form','CXGN.List', 'CXGN.BreedersToolbox.AddTrial','CXGN.BreedersToolbox.UploadTrial','CXGN.BreedersToolbox.Trial', 'CXGN.Trial','CXGN.BreedersToolbox.GenotypingTrial','CXGN.BreedersToolbox.Accessions', 'CXGN.BreedersToolbox.UploadPedigrees','CXGN.BreedersToolbox.Crosses','CXGN.BreedersToolbox.FieldBook','CXGN.BreedersToolbox.UploadPhenotype', 'CXGN.BreedersToolbox.HTMLSelect', 'CXGN.BreederSearch', 'CXGN.Trial','CXGN.TrialTreeFolders' ] &>

<& /page/page_title.mas, title=>"Upload Factory" &>

<style>
.ui-autocomplete {
    z-index: 5000;
}
</style>

<div class="container-fluid">

<div class="well well-sm">
    <h3>Archived files</h3>
        <&| /page/info_section.mas, title => ' ',  id => 'archived_files_table_section', collapsible => 1, collapsed => 0 &>
            <table style="width:100%">
                <tr>
                    <td>
                    </td>
                    <td>
                        &nbsp; &nbsp; &nbsp; &nbsp; 
                    </td>
                    <td>
                        <div style="display:flex;justify-content:flex-end;">
                            <form class="form-horizontal" role="form" method="post" enctype="multipart/form-data" encoding="multipart/form-data" id="upload_factory_file_form" name="upload_factory_file_form">
                                <div class="form-group">
                                    <label class="col-sm-4 control-label">Archive files: </label>
                                    <div class="col-sm-6">
                                        <input class="form-control form-control-sm" type="file" id="upload_factory_archive_new_file" name="upload_factory_archive_new_file[]" multiple>
                                    </div>
                                    <div class="col-sm-2">
                                        <button type="submit" class="btn btn-primary" id="upload_factory_new_file_btn"><span class="glyphicon glyphicon-floppy-open"></span></button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </td>
            <table id="upload_factory_archived_files_table">
                <thead>
                </thead>
                <tbody>
                </tbody>
                <tfoot>
                </tfoot>
            </table>
        </&>
</div>

<div class="well well-sm">
<h3>File validation</h3>
    <&| /page/info_section.mas, title => ' ', subtitle => 'Some file types include a file validation step. Be sure to complete the upload after passing validation. Warning and error conditions will cause an upload to fail.', id => 'in_progress_validations_table_section', collapsible => 1, collapsed => 1 &>
        <img id="validation-loading-spinner" src="/img/wheel.gif" alt="loading" hidden>
        <table id="upload_factory_validated_files_table">
            <thead>
            </thead>
            <tbody>
            </tbody>
            <tfoot>
            </tfoot>
        </table>
        </&>
</div>

<div class="well well-sm">
<h3>Uploads in-progress</h3>
    <&| /page/info_section.mas, title => ' ', id => 'in_progress_uploads_table_section', collapsible => 1, collapsed => 1 &>
        <img id="uploads-loading-spinner" src="/img/wheel.gif" alt="loading" hidden>
        <table id="upload_factory_in_progress_uploads_table">
            <thead>
            </thead>
            <tbody>
            </tbody>
            <tfoot>
            </tfoot>
        </table>
    </&>
</div>


<div class="well well-sm">
<h3>Completed uploads</h3>
    <&| /page/info_section.mas, title => ' ', id => 'completed_uploads_table_section', collapsible => 1, collapsed => 1 &>
        <br>
        <button id="dismiss_completed_uploads_btn" class="btn btn-sm btn-primary">Dismiss all completed uploads</button> &nbsp; &nbsp;
        <button id="dismiss_failed_uploads_btn" class="btn btn-sm btn-primary">Dismiss all failed and timed-out uploads</button> &nbsp; &nbsp;
        <br>
        <br>
        <img id="completed-loading-spinner" src="/img/wheel.gif" alt="loading" hidden>
        <table id="upload_factory_completed_uploads_table">
            <thead>
            </thead>
            <tbody>
            </tbody>
            <tfoot>
            </tfoot>
        </table>
    </&>
</div>


<div class="modal fade" id="upload_type_choice_dialog" name="upload_type_choice_dialog" tabindex="-1" role="dialog" aria-labelledby="uploadTypeChoiceDialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="text-align: center">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="uploadTypeChoiceDialog">Available Upload Types</h4>
            </div>
            <div class="modal-body">
                <div class="container-fluid">
                    <b>There are additional options for this upload:</b>
                    <br>
                    <br>
                    <div id="upload_type_choices_div">
                        <div id="plant_upload_type_choices_div" hidden>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button id="close_upload_type_choice_dialog" type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="validate_upload_confirm_submit" name="validate_upload_confirm_submit" tabindex="-1" role="dialog" aria-labelledby="validateUploadConfirmSubmit">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="text-align: center">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="validateUploadConfirmSubmit">Review Submission</h4>
            </div>
            <div class="modal-body">
                <div class="container-fluid">
                    <b>Review the submission. Click 'Submit' when you are ready to start file processing.</b>
                    <br>
                    <br>
                    <label class="control-label">Ignore warnings when possible: </label>
                    <input id="upload_submit_ignore_warnings" name="upload_submit_ignore_warnings" type="checkbox" data-toggle="toggle" encoding="multipart/form-data">
                    <br>
                    <br>
                    <div id="validate_upload_review_text"></div>
                    <div id="upload_validation_parameters" hidden></div>
                </div>
            </div>
            <div class="modal-footer">
                <button id="close_validate_upload_confirm_submit" type="button" class="btn btn-default" data-dismiss="modal">Close</button>&nbsp;<button class="btn btn-info" id="submit_validate_upload">Submit</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="view_report_dialog" name="view_report_dialog" tabindex="-1" role="dialog" aria-labelledby="viewReport">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="text-align: center">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="viewReport">Upload Report</h4>
            </div>
            <div class="modal-body">
                <div id="report_content_div"></div>
            </div>
            <div class="modal-footer">
                <button id="close_report_dialog_btn" type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<& /file_formats/trial_upload.mas &>

<& /file_formats/plant_upload.mas &>

<& /file_formats/subplot_plant_upload.mas &>

<& /file_formats/subplot_upload.mas &>

<& /file_formats/genotype_plate_upload.mas &>

<& /file_formats/genotype_data_upload.mas &>

<& /file_formats/location_upload.mas &>

<& /file_formats/accession_upload.mas, editable_stock_props => $editable_stock_props, editable_stock_props_definitions => $editable_stock_props_definitions &>

<& /file_formats/seedlot_upload.mas &>

<& /file_formats/pedigree_upload.mas &>

<& /file_formats/cross_upload.mas &>

<& /file_formats/gps_upload.mas &>

<& /file_formats/change_accessions_upload.mas &>

<& /file_formats/entry_numbers_upload.mas &>

<& /file_formats/phenotype_upload.mas &>

<& /breeders_toolbox/trial/create_spreadsheet_dialog.mas &>

<& /file_formats/high_dimensional_phenotype_upload.mas &>

<& /file_formats/image_upload.mas &>

<& /file_formats/soil_data_upload.mas &>

<& /file_formats/vector_upload.mas, editable_vector_props => $editable_vector_props, editable_stock_props_definitions => $editable_stock_props_definitions &>

<& /file_formats/spatial_layout.mas &>

<& /file_formats/treatment_upload.mas &>

<& /file_formats/trial_additional_file.mas &>

<script>

function upload_type_options() {
    return "<% $allowed_upload_types %>";
}

function fire_refresh() {
    jsMod["upload_factory"].refresh_upload_tables('<% $sp_person_id %>');
}

jQuery(document).ready(function(){

    jsMod["upload_factory"].load_archived_files_table('<% $sp_person_id %>');
    jsMod["upload_factory"].refresh_upload_tables('<% $sp_person_id %>');

    setInterval(fire_refresh, 60000);

    jQuery('#upload_factory_new_file_btn').click(function(event){
        event.preventDefault();
        var uploadFiles = document.getElementById('upload_factory_archive_new_file').files;
        if (!uploadFiles || uploadFiles.length === 0) {
            alert("Please select at least one file.");
            return;
        }

        console.log(uploadFiles);

        jQuery('#working_modal').modal("show");
        jQuery("#upload_factory_file_form").attr("action", '/ajax/tools/documents/upload');
        jQuery("#upload_factory_file_form").submit();
    });

    jQuery("#upload_factory_file_form").iframePostForm({
        json: true,
        post: function () { },
        timeout: 180,
        complete: function (response) {
            jQuery('#working_modal').modal("hide");
            if (response.error){
                alert("File upload failed, check console");
            } else {
                jsMod["upload_factory"].load_archived_files_table('<% $sp_person_id %>');
            }
        }
    });

    jQuery(document).on('click','.process-file-btn',function() {
        let file_id = jQuery(this).attr('id').replace('process_file_', '');
        let file_name = jQuery('#file_timestamp_'+file_id).text()+"_"+jQuery('#file_name_'+file_id).text();
        let upload_type = jQuery("#upload_select_type_"+file_id).val();

        jsMod["upload_factory"].process_file({file_name : file_name, file_id : file_id}, upload_type, {
            default_seedlot_material_type : "<%$default_seedlot_material_type%>",
            user_role : "<%$user_role%>"
        });
    });

    jQuery(document).on('click','.check-format-btn', function() {
        let file_id = jQuery(this).attr('id').replace('check_format_', '');
        let upload_type = jQuery("#upload_select_type_"+file_id).val();
        jsMod["upload_factory"].display_upload_formats(upload_type, {
            default_seedlot_material_type : "<%$default_seedlot_material_type%>",
            user_role : "<%$user_role%>"
        });
    });

    jQuery(document).on('change', '.upload-type-select', function() {
        let file_id = jQuery(this).attr('id').replace('upload_select_type_', '');
        let upload_type = jQuery("#upload_select_type_"+file_id).val();
        if (upload_type != null && upload_type != "" && upload_type != "null_choice" && upload_type != "fieldbook_phenotypes") {
            jQuery('#check_format_'+file_id).prop('disabled', false);
        } else {
            jQuery('#check_format_'+file_id).prop('disabled', true);
        }
        jsMod["upload_factory"].save_file_type(file_id, upload_type);
    });

    jQuery(document).on('click', '.job-dismiss-btn', function() {
        let job_id = jQuery(this).attr("id").replace('dismiss_job_', '');
        jsMod["job"].dismiss_job(job_id);
    });

    jQuery(document).on('click', '.job-cancel-btn', function() {
        let job_id = jQuery(this).attr("id").replace('cancel_job_', '');
        jsMod["job"].cancel_job(job_id);
    });

    jQuery(document).on('click', '.validation-commit-btn', function() {
        let job_id = jQuery(this).attr("id").replace('validation_commit_', '');
        jsMod["upload_factory"].commit_upload_job(job_id);
    });

    jQuery(document).on('click', '.view-report-btn', function() {
        let job_id = jQuery(this).attr("id").replace('job_report_', '');
        jQuery('#view_report_dialog').modal("show");
        let success = '';
        let warnings = '';
        let errors = '';
        if (jsMod["upload_factory"].job_dict[job_id].args.additional_args?.success_messages) {
            success = `<p class="list-group-item-success" >${jsMod["upload_factory"].job_dict[job_id].args.additional_args.success_messages}</p>`;
        }
        if (jsMod["upload_factory"].job_dict[job_id].args.additional_args?.warning_messages) {
            warnings = `<p class="list-group-item-warning" >${jsMod["upload_factory"].job_dict[job_id].args.additional_args.warning_messages}</p>`;
        }
        if (jsMod["upload_factory"].job_dict[job_id].args.additional_args?.error_messages) {
            errors = `<p class="list-group-item-danger" >${jsMod["upload_factory"].job_dict[job_id].args.additional_args.error_messages}</p>`;
        }
        jQuery('#report_content_div').html(`${success}${warnings}${errors}`);
    });

    jQuery('#dismiss_completed_uploads_btn').on('click', function(){
        jQuery.ajax({
            url : '/ajax/job/dismiss_completed_uploads/'+"<% $sp_person_id %>",
            beforeSend : function() {
                jQuery('#working_modal').modal("show");
            },
            success : function(response) {
                jQuery('#working_modal').modal("hide");
                if (response.error) {
                    alert(response.error);
                } else {
                    alert("Uploads dismissed.");
                    jsMod["upload_factory"].refresh_upload_tables();
                }
            },
            error : function() {
                jQuery('#working_modal').modal("hide");
                alert("An error occurred dismissing completed uploads, check console.");
            }
        });
    });

    jQuery('#dismiss_failed_uploads_btn').on('click', function(){
        jQuery.ajax({
            url : '/ajax/job/dismiss_dead_uploads/'+"<% $sp_person_id %>",
            beforeSend : function() {
                jQuery('#working_modal').modal("show");
            },
            success : function(response) {
                jQuery('#working_modal').modal("hide");
                if (response.error) {
                    alert(response.error);
                } else {
                    alert("Uploads dismissed.");
                    jsMod["upload_factory"].refresh_upload_tables();
                }
            },
            error : function() {
                jQuery('#working_modal').modal("hide");
                alert("An error occurred dismissing failed and timed out uploads, check console.");
            }
        });
    });

    // jQuery('#check_file_format_select').html(upload_type_options());

    // jQuery('#check_file_format_select').on('change', function(){
    //     let upload_type = jQuery('#check_file_format_select').val();
    //     jsMod["upload_factory"].display_upload_formats(upload_type, {
    //         default_seedlot_material_type : "<%$default_seedlot_material_type%>",
    //         user_role : "<%$user_role%>"
    //     });
    // });

    jQuery('#submit_validate_upload').on('click', jsMod["upload_factory"].submit_upload_job);

});
</script>