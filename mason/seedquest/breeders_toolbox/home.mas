
<%args>
</%args>

<%init>
use utf8;
# Load translation hash for current language (reads sq_lang cookie)
my $L = $m->comp('/site/sq_loc.mas', _hash => 1);
</%init>

<& /page/page_title.mas, title => $L->{dashboard_title} &>

<style>
/* Expand BreedBase default 800px #outercontainer on this page */
#outercontainer { max-width: 1260px !important; width: 95% !important; margin: 0 auto !important; }
#pagetitle { text-align: center; margin-bottom: 4px; }
#pagetitle_h3 { font-weight: 700; font-size: 22px; color: #1e293b; letter-spacing: 0.5px; }
.sq-dash-wrap { max-width: 100%; margin: 0 auto; padding: 0; }

/* ─── Hero Quick-Access Cards ─── */
.sq-hero { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-bottom: 32px; }

.sq-card {
    position: relative;
    border-radius: 14px;
    padding: 24px 20px 20px;
    color: #fff;
    text-decoration: none !important;
    overflow: hidden;
    transition: transform 0.25s cubic-bezier(.4,0,.2,1), box-shadow 0.25s cubic-bezier(.4,0,.2,1);
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    cursor: pointer;
    display: block;
}
.sq-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.22);
    color: #fff;
    text-decoration: none !important;
}
.sq-card:focus { outline: 2px solid #fff; outline-offset: -4px; }
/* Shimmer effect on hover */
.sq-card::after {
    content: '';
    position: absolute;
    top: 0; left: -75%;
    width: 50%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.18), transparent);
    transition: left 0.5s;
}
.sq-card:hover::after { left: 125%; }

.sq-card-icon {
    font-size: 28px;
    margin-bottom: 10px;
    display: inline-block;
    opacity: 0.9;
}
.sq-card h3 {
    margin: 0 0 6px;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.3px;
    color: #fff;
}
.sq-card p {
    margin: 0;
    font-size: 12.5px;
    opacity: 0.88;
    line-height: 1.4;
    color: #fff;
}

/* Card gradients — vibrant, curated palettes */
.sq-card--trials   { background: linear-gradient(135deg, #f59e0b, #d97706); }
.sq-card--weather  { background: linear-gradient(135deg, #06b6d4, #0284c7); }
.sq-card--qc       { background: linear-gradient(135deg, #ef4444, #dc2626); }

/* ─── Section Grid ─── */
.sq-sections {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 32px;
}

/* ─── Section Panels ─── */
.sq-panel {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.06);
    transition: box-shadow 0.2s;
}
.sq-panel:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.1); }

.sq-panel-head {
    padding: 14px 18px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.3px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
}
.sq-panel-head .glyphicon { font-size: 16px; }

/* Panel head color accents */
.sq-panel-head--green  { background: linear-gradient(90deg, #ecfdf5, #f0fdf4); color: #065f46; }
.sq-panel-head--blue   { background: linear-gradient(90deg, #eff6ff, #f0f9ff); color: #1e40af; }
.sq-panel-head--purple { background: linear-gradient(90deg, #f5f3ff, #faf5ff); color: #5b21b6; }
.sq-panel-head--amber  { background: linear-gradient(90deg, #fffbeb, #fefce8); color: #92400e; }
.sq-panel-head--slate  { background: linear-gradient(90deg, #f1f5f9, #f8fafc); color: #334155; }

/* ─── Link Items ─── */
.sq-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 18px;
    color: #334155 !important;
    text-decoration: none !important;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    transition: background 0.15s, padding-left 0.2s;
}
.sq-link:last-child { border-bottom: none; }
.sq-link:hover {
    background: #f8fafc;
    padding-left: 22px;
    color: #1e40af !important;
    text-decoration: none !important;
}

.sq-link-icon {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
}
/* Icon background colors */
.sq-ico-green  { background: #d1fae5; color: #059669; }
.sq-ico-blue   { background: #dbeafe; color: #2563eb; }
.sq-ico-purple { background: #ede9fe; color: #7c3aed; }
.sq-ico-amber  { background: #fef3c7; color: #d97706; }
.sq-ico-red    { background: #fee2e2; color: #dc2626; }
.sq-ico-slate  { background: #e2e8f0; color: #475569; }
.sq-ico-teal   { background: #ccfbf1; color: #0d9488; }
.sq-ico-rose   { background: #ffe4e6; color: #e11d48; }

.sq-link-text h4 {
    margin: 0;
    font-size: 13.5px;
    font-weight: 600;
    color: inherit;
}
.sq-link-text p {
    margin: 2px 0 0;
    font-size: 11.5px;
    color: #94a3b8;
    line-height: 1.3;
}

/* Arrow hint on hover */
.sq-link::after {
    content: '\e080';
    font-family: 'Glyphicons Halflings';
    font-size: 10px;
    margin-left: auto;
    opacity: 0;
    color: #94a3b8;
    transition: opacity 0.2s, transform 0.2s;
    transform: translateX(-4px);
}
.sq-link:hover::after {
    opacity: 1;
    transform: translateX(0);
}

/* ─── Responsive ─── */
@media (max-width: 991px) {
    .sq-hero { grid-template-columns: repeat(2, 1fr); }
    .sq-sections { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
    .sq-hero { grid-template-columns: 1fr; }
}
</style>

<div class="sq-dash-wrap">

    <!-- ═══ Hero: Quick Access Cards ═══ -->
    <div class="sq-hero">
        <a href="/breeders/trials" class="sq-card sq-card--trials">
            <span class="glyphicon glyphicon-grain sq-card-icon"></span>
            <h3 data-i18n="field_trials"><% $L->{field_trials} %></h3>
            <p data-i18n="field_trials_desc"><% $L->{field_trials_desc} %></p>
        </a>
        <a href="/tools/weather/gdd" class="sq-card sq-card--weather">
            <span class="glyphicon glyphicon-cloud sq-card-icon"></span>
            <h3 data-i18n="weather_gdd"><% $L->{weather_gdd} %></h3>
            <p data-i18n="weather_gdd_desc"><% $L->{weather_gdd_desc} %></p>
        </a>
        <a href="/tools/seedquest/qualitycontrol" class="sq-card sq-card--qc">
            <span class="glyphicon glyphicon-check sq-card-icon"></span>
            <h3 data-i18n="quality_control"><% $L->{quality_control} %></h3>
            <p data-i18n="quality_control_desc"><% $L->{quality_control_desc} %></p>
        </a>
    </div>

    <!-- ═══ Section Panels ═══ -->
    <div class="sq-sections">

        <!-- ── Germplasm & Inventory ── -->
        <div class="sq-panel">
            <div class="sq-panel-head sq-panel-head--green">
                <span class="glyphicon glyphicon-leaf"></span> <span data-i18n="germplasm_inv"><% $L->{germplasm_inv} %></span>
            </div>
            <a href="/breeders/manage_programs" class="sq-link">
                <div class="sq-link-icon sq-ico-green"><span class="glyphicon glyphicon-briefcase"></span></div>
                <div class="sq-link-text"><h4 data-i18n="breeding_programs"><% $L->{breeding_programs} %></h4><p data-i18n="breeding_programs_d"><% $L->{breeding_programs_d} %></p></div>
            </a>
            <a href="/breeders/accessions" class="sq-link">
                <div class="sq-link-icon sq-ico-teal"><span class="glyphicon glyphicon-leaf"></span></div>
                <div class="sq-link-text"><h4 data-i18n="accessions"><% $L->{accessions} %></h4><p data-i18n="accessions_d"><% $L->{accessions_d} %></p></div>
            </a>
            <a href="/breeders/seedlots" class="sq-link">
                <div class="sq-link-icon sq-ico-amber"><span class="glyphicon glyphicon-oil"></span></div>
                <div class="sq-link-text"><h4 data-i18n="seed_lots"><% $L->{seed_lots} %></h4><p data-i18n="seed_lots_d"><% $L->{seed_lots_d} %></p></div>
            </a>
            <a href="/breeders/crosses" class="sq-link">
                <div class="sq-link-icon sq-ico-purple"><span class="glyphicon glyphicon-random"></span></div>
                <div class="sq-link-text"><h4 data-i18n="crosses"><% $L->{crosses} %></h4><p data-i18n="crosses_d"><% $L->{crosses_d} %></p></div>
            </a>
            <a href="/order/stocks/view" class="sq-link">
                <div class="sq-link-icon sq-ico-blue"><span class="glyphicon glyphicon-shopping-cart"></span></div>
                <div class="sq-link-text"><h4 data-i18n="order_stocks"><% $L->{order_stocks} %></h4><p data-i18n="order_stocks_d"><% $L->{order_stocks_d} %></p></div>
            </a>
        </div>

        <!-- ── Field & Lab Operations ── -->
        <div class="sq-panel">
            <div class="sq-panel-head sq-panel-head--blue">
                <span class="glyphicon glyphicon-wrench"></span> <span data-i18n="field_lab_ops"><% $L->{field_lab_ops} %></span>
            </div>
            <a href="/breeders/locations" class="sq-link">
                <div class="sq-link-icon sq-ico-blue"><span class="glyphicon glyphicon-map-marker"></span></div>
                <div class="sq-link-text"><h4 data-i18n="locations"><% $L->{locations} %></h4><p data-i18n="locations_d"><% $L->{locations_d} %></p></div>
            </a>
            <a href="/breeders/phenotyping" class="sq-link">
                <div class="sq-link-icon sq-ico-green"><span class="glyphicon glyphicon-stats"></span></div>
                <div class="sq-link-text"><h4 data-i18n="phenotyping"><% $L->{phenotyping} %></h4><p data-i18n="phenotyping_d"><% $L->{phenotyping_d} %></p></div>
            </a>
            <a href="/fieldbook" class="sq-link">
                <div class="sq-link-icon sq-ico-purple"><span class="glyphicon glyphicon-phone"></span></div>
                <div class="sq-link-text"><h4 data-i18n="field_book"><% $L->{field_book} %></h4><p data-i18n="field_book_d"><% $L->{field_book_d} %></p></div>
            </a>
            <a href="/barcode" class="sq-link">
                <div class="sq-link-icon sq-ico-slate"><span class="glyphicon glyphicon-barcode"></span></div>
                <div class="sq-link-text"><h4 data-i18n="barcodes"><% $L->{barcodes} %></h4><p data-i18n="barcodes_d"><% $L->{barcodes_d} %></p></div>
            </a>
            <a href="/tools/label_designer" class="sq-link">
                <div class="sq-link-icon sq-ico-amber"><span class="glyphicon glyphicon-tags"></span></div>
                <div class="sq-link-text"><h4 data-i18n="label_designer"><% $L->{label_designer} %></h4><p data-i18n="label_designer_d"><% $L->{label_designer_d} %></p></div>
            </a>
        </div>

        <!-- ── Phenotype Analysis ── -->
        <div class="sq-panel">
            <div class="sq-panel-head sq-panel-head--purple">
                <span class="glyphicon glyphicon-signal"></span> <span data-i18n="phenotype_analysis"><% $L->{phenotype_analysis} %></span>
            </div>
            <a href="/selection/index" class="sq-link">
                <div class="sq-link-icon sq-ico-purple"><span class="glyphicon glyphicon-stats"></span></div>
                <div class="sq-link-text"><h4 data-i18n="selection_index"><% $L->{selection_index} %></h4><p data-i18n="selection_index_d"><% $L->{selection_index_d} %></p></div>
            </a>
            <a href="/correlation/analysis" class="sq-link">
                <div class="sq-link-icon sq-ico-blue"><span class="glyphicon glyphicon-resize-small"></span></div>
                <div class="sq-link-text"><h4 data-i18n="correlation"><% $L->{correlation} %></h4><p data-i18n="correlation_d"><% $L->{correlation_d} %></p></div>
            </a>
            <a href="/tools/mixedmodels" class="sq-link">
                <div class="sq-link-icon sq-ico-teal"><span class="glyphicon glyphicon-random"></span></div>
                <div class="sq-link-text"><h4 data-i18n="mixed_models"><% $L->{mixed_models} %></h4><p data-i18n="mixed_models_d"><% $L->{mixed_models_d} %></p></div>
            </a>
            <a href="/tools/stability" class="sq-link">
                <div class="sq-link-icon sq-ico-amber"><span class="glyphicon glyphicon-adjust"></span></div>
                <div class="sq-link-text"><h4 data-i18n="stability"><% $L->{stability} %></h4><p data-i18n="stability_d"><% $L->{stability_d} %></p></div>
            </a>
            <a href="/tools/heritability" class="sq-link">
                <div class="sq-link-icon sq-ico-green"><span class="glyphicon glyphicon-scale"></span></div>
                <div class="sq-link-text"><h4 data-i18n="heritability"><% $L->{heritability} %></h4><p data-i18n="heritability_d"><% $L->{heritability_d} %></p></div>
            </a>
            <a href="/tools/trial/comparison/list" class="sq-link">
                <div class="sq-link-icon sq-ico-rose"><span class="glyphicon glyphicon-transfer"></span></div>
                <div class="sq-link-text"><h4 data-i18n="compare_trials"><% $L->{compare_trials} %></h4><p data-i18n="compare_trials_d"><% $L->{compare_trials_d} %></p></div>
            </a>
            <a href="/tools/boxplotter" class="sq-link">
                <div class="sq-link-icon sq-ico-slate"><span class="glyphicon glyphicon-modal-window"></span></div>
                <div class="sq-link-text"><h4 data-i18n="boxplotter"><% $L->{boxplotter} %></h4><p data-i18n="boxplotter_d"><% $L->{boxplotter_d} %></p></div>
            </a>
        </div>

        <!-- ── Data Management & Admin ── -->
        <div class="sq-panel">
            <div class="sq-panel-head sq-panel-head--amber">
                <span class="glyphicon glyphicon-download"></span> <span data-i18n="data_management"><% $L->{data_management} %></span>
            </div>
            <a href="/breeders/download" class="sq-link">
                <div class="sq-link-icon sq-ico-blue"><span class="glyphicon glyphicon-download"></span></div>
                <div class="sq-link-text"><h4 data-i18n="download_data"><% $L->{download_data} %></h4><p data-i18n="download_data_d"><% $L->{download_data_d} %></p></div>
            </a>
            <a href="/breeders/upload" class="sq-link">
                <div class="sq-link-icon sq-ico-green"><span class="glyphicon glyphicon-upload"></span></div>
                <div class="sq-link-text"><h4 data-i18n="upload_data"><% $L->{upload_data} %></h4><p data-i18n="upload_data_d"><% $L->{upload_data_d} %></p></div>
            </a>
            <a href="/tools/report/" class="sq-link">
                <div class="sq-link-icon sq-ico-purple"><span class="glyphicon glyphicon-file"></span></div>
                <div class="sq-link-text"><h4 data-i18n="report_factory"><% $L->{report_factory} %></h4><p data-i18n="report_factory_d"><% $L->{report_factory_d} %></p></div>
            </a>
            <a href="/breeders/file_share_dump" class="sq-link">
                <div class="sq-link-icon sq-ico-amber"><span class="glyphicon glyphicon-folder-open"></span></div>
                <div class="sq-link-text"><h4 data-i18n="file_share"><% $L->{file_share} %></h4><p data-i18n="file_share_d"><% $L->{file_share_d} %></p></div>
            </a>

            <!-- Admin sub-section -->
            <div class="sq-panel-head sq-panel-head--slate" style="margin-top: 2px;">
                <span class="glyphicon glyphicon-cog"></span> <span data-i18n="administration"><% $L->{administration} %></span>
            </div>
            <a href="/breeders/manage_roles/" class="sq-link">
                <div class="sq-link-icon sq-ico-slate"><span class="glyphicon glyphicon-user"></span></div>
                <div class="sq-link-text"><h4 data-i18n="user_roles"><% $L->{user_roles} %></h4><p data-i18n="user_roles_d"><% $L->{user_roles_d} %></p></div>
            </a>
            <a href="/tools/onto/" class="sq-link">
                <div class="sq-link-icon sq-ico-teal"><span class="glyphicon glyphicon-book"></span></div>
                <div class="sq-link-text"><h4 data-i18n="ontology_browser"><% $L->{ontology_browser} %></h4><p data-i18n="ontology_browser_d"><% $L->{ontology_browser_d} %></p></div>
            </a>
        </div>

    </div>
</div>
