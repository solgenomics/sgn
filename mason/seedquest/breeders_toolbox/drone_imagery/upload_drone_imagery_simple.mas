<%args>
</%args>

<& /util/import_javascript.mas, classes => [ 'jquery', 'CXGN.BreederSearch' ] &>

<style>
.drone-upload-simple {
    max-width: 600px;
    margin: 2rem auto;
    padding: 2rem;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

.drone-upload-simple h2 {
    text-align: center;
    color: #2c3e50;
    margin-bottom: 1.5rem;
    font-weight: 600;
}

.drone-upload-simple .form-group {
    margin-bottom: 1.5rem;
}

.drone-upload-simple label {
    font-weight: 500;
    color: #495057;
    margin-bottom: 0.5rem;
    display: block;
}

.drone-upload-simple select,
.drone-upload-simple input[type="file"] {
    width: 100%;
    padding: 0.75rem;
    border: 2px solid #dee2e6;
    border-radius: 0.5rem;
    font-size: 1rem;
    transition: border-color 0.2s;
}

.drone-upload-simple select:focus,
.drone-upload-simple input:focus {
    border-color: #007bff;
    outline: none;
}

.drone-upload-simple .checkbox-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 0;
}

.drone-upload-simple .checkbox-group input[type="checkbox"] {
    width: 1.25rem;
    height: 1.25rem;
}

.drone-upload-simple .btn-upload {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
}

.drone-upload-simple .btn-upload:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(40, 167, 69, 0.4);
}

.drone-upload-simple .btn-upload:disabled {
    background: #adb5bd;
    cursor: not-allowed;
    transform: none;
}

.drone-upload-simple .spinner {
    display: none;
    text-align: center;
    padding: 2rem;
}

.drone-upload-simple .spinner.active {
    display: block;
}

.drone-upload-simple .spinner::after {
    content: '';
    display: inline-block;
    width: 40px;
    height: 40px;
    border: 3px solid #f3f3f3;
    border-top: 3px solid #28a745;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.drone-upload-simple .info-box {
    background: #e3f2fd;
    border-left: 4px solid #2196f3;
    padding: 1rem;
    margin: 1rem 0;
    border-radius: 0 0.5rem 0.5rem 0;
    font-size: 0.9rem;
}

.drone-upload-simple .detected-info {
    background: #e8f5e9;
    border: 1px solid #c8e6c9;
    border-radius: 0.5rem;
    padding: 1rem;
    margin: 1rem 0;
    display: none;
}

.drone-upload-simple .detected-info.visible {
    display: block;
}

.drone-upload-simple .advanced-link {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.9rem;
}
</style>

<div class="drone-upload-simple">
    <h2>📷 Upload Drone Imagery</h2>
    
    <form id="drone_upload_simple_form" enctype="multipart/form-data">
        
        <div class="form-group">
            <label for="trial_select">Select Field Trial</label>
            <div id="drone_simple_trial_select_div">
                <select id="trial_select" name="trial_id" class="form-control">
                    <option value="">Loading trials...</option>
                </select>
            </div>
        </div>
        
        <div class="form-group">
            <label for="upload_zip">Upload Images (ZIP)</label>
            <input type="file" id="upload_zip" name="upload_zip" accept=".zip" />
        </div>
        
        <div class="info-box">
            <strong>Auto-detection:</strong> Date, sensor type, and imaging event name will be extracted automatically from image EXIF data.
        </div>
        
        <div class="detected-info" id="detected_info">
            <strong>Detected:</strong><br/>
            <span id="detected_sensor">Sensor: --</span><br/>
            <span id="detected_date">Date: --</span>
        </div>
        
        <div class="checkbox-group">
            <input type="checkbox" id="use_odm" name="use_odm" checked />
            <label for="use_odm">Stitch raw images with OpenDroneMap</label>
        </div>
        
        <div class="spinner" id="upload_spinner">
            <p>Processing images with OpenDroneMap...</p>
            <p style="font-size: 0.85rem; color: #666;">This may take several minutes</p>
        </div>
        
        <button type="submit" class="btn-upload" id="btn_upload">
            Upload & Process
        </button>
    </form>
    
    <div class="advanced-link">
        <a href="#" onclick="jQuery('#upload_drone_imagery_dialog').modal('show'); return false;">
            Need more options? Use Advanced Upload
        </a>
    </div>
</div>

<script>

jQuery(document).ready(function() {
    // Load trials dropdown
    loadTrials();
    
    // File change - detect EXIF
    jQuery('#upload_zip').on('change', function() {
        var file = this.files[0];
        if (file) {
            // Show placeholder info (real EXIF detection happens server-side)
            jQuery('#detected_info').addClass('visible');
            jQuery('#detected_sensor').text('Sensor: Will be detected from images');
            jQuery('#detected_date').text('Date: Will be detected from images');
        }
    });
    
    // Form submit
    jQuery('#drone_upload_simple_form').on('submit', function(e) {
        e.preventDefault();
        
        var trial_id = jQuery('#trial_select').val();
        var file = jQuery('#upload_zip')[0].files[0];
        var use_odm = jQuery('#use_odm').is(':checked');
        
        if (!trial_id) {
            alert('Please select a field trial');
            return;
        }
        
        if (!file) {
            alert('Please select a ZIP file with images');
            return;
        }
        
        // Show spinner
        jQuery('#upload_spinner').addClass('active');
        jQuery('#btn_upload').prop('disabled', true);
        
        var formData = new FormData();
        formData.append('trial_id', trial_id);
        formData.append('upload_zip', file);
        formData.append('use_odm', use_odm ? '1' : '0');
        formData.append('auto_detect', '1');
        
        jQuery.ajax({
            url: '/ajax/drone_imagery/simple_upload',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            timeout: 300000, // 5 minute timeout for large files
            success: function(response) {
                jQuery('#upload_spinner').removeClass('active');
                jQuery('#btn_upload').prop('disabled', false);
                
                if (response.success) {
                    // Show detected info
                    if (response.detected) {
                        jQuery('#detected_info').addClass('visible');
                        jQuery('#detected_sensor').text('Sensor: ' + (response.detected.sensor_display || response.detected.sensor));
                        jQuery('#detected_date').text('Date: ' + response.detected.date);
                        
                        // Show camera make/model if available
                        if (response.detected.make || response.detected.model) {
                            jQuery('#detected_info').append('<br><span>Camera: ' + 
                                (response.detected.make || '') + ' ' + (response.detected.model || '') + '</span>');
                        }
                    }
                    
                    // Show success message with detected info
                    var msg = 'Upload successful!\n\n';
                    if (response.detected) {
                        msg += 'Detected sensor: ' + (response.detected.sensor_display || response.detected.sensor) + '\n';
                        msg += 'Date: ' + response.detected.date + '\n';
                        msg += 'Imaging Event: ' + response.detected.drone_run_name + '\n\n';
                    }
                    msg += response.message;
                    
                    alert(msg);
                    window.location.href = '/breeders/drone_imagery';
                } else {
                    alert('Error: ' + (response.error || 'Unknown error'));
                }
            },
            error: function(xhr, status, error) {
                jQuery('#upload_spinner').removeClass('active');
                jQuery('#btn_upload').prop('disabled', false);
                
                var errorMsg = 'Upload failed: ';
                if (status === 'timeout') {
                    errorMsg += 'Request timed out. The file may be too large or the server is busy.';
                } else if (xhr.status === 0) {
                    errorMsg += 'Network error. Please check your connection.';
                } else if (xhr.status === 413) {
                    errorMsg += 'File too large. Please use a smaller ZIP file.';
                } else if (xhr.status === 500) {
                    errorMsg += 'Server error. Please try again later.';
                } else if (xhr.responseJSON && xhr.responseJSON.error) {
                    errorMsg += xhr.responseJSON.error;
                } else {
                    errorMsg += error || status || 'Unknown error';
                }
                
                console.error('Upload error:', {status: status, error: error, xhr: xhr});
                alert(errorMsg);
            }
        });
    });
});

function loadTrials() {
    jQuery.ajax({
        url: '/ajax/html/select/trials',
        type: 'GET',
        dataType: 'json',
        success: function(response) {
            var select = jQuery('#trial_select');
            select.empty();
            select.append('<option value="">-- Select Trial --</option>');
            
            // Response is JSON with .select field containing HTML
            if (response && response.select) {
                var tempDiv = jQuery('<div>').html(response.select);
                tempDiv.find('option').each(function() {
                    var val = jQuery(this).val();
                    var text = jQuery(this).text();
                    if (val) {
                        select.append('<option value="' + val + '">' + text + '</option>');
                    }
                });
            }
        },
        error: function() {
            jQuery('#trial_select').html('<option value="">Error loading trials</option>');
        }
    });
}

</script>

<& /breeders_toolbox/drone_imagery/upload_drone_imagery_dialogs.mas &>
